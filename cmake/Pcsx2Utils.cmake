function(write_svnrev_h)
    # Create a minimal svnrev.h so common/ headers compile
    file(MAKE_DIRECTORY "${CMAKE_BINARY_DIR}/common/include")
    file(WRITE "${CMAKE_BINARY_DIR}/common/include/svnrev.h"
"// Auto-generated by Pcsx2Utils.cmake iOS stub\n"
"#pragma once\n"
"#define SVN_REV_UNKNOWN 1\n"
"#define SVN_REV 0\n"
"#define SVN_MODS 0\n"
"#define GIT_TAG_STRING \"iPSX2-dev\"\n"
    )
endfunction()

