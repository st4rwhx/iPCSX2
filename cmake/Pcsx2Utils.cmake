# Pcsx2Utils.cmake — iOS stub
# Replaces the full PCSX2 cmake utils for the iOS build.
# All macros are no-ops or minimal implementations sufficient for iOS/Xcode.

macro(check_no_parenthesis_in_path)
    # No-op: path check not needed for iOS CI builds
endmacro()

macro(detect_operating_system)
    set(LINUX FALSE)
    set(FREEBSD FALSE)
    set(Windows FALSE)
    set(OSX FALSE)
    if(WIN32)
        set(Windows TRUE)
    elseif(APPLE)
        set(OSX TRUE)
    endif()
endmacro()

macro(detect_compiler)
    if(CMAKE_CXX_COMPILER_ID MATCHES "Clang")
        set(USE_CLANG TRUE)
        set(USE_GCC FALSE)
        set(USE_MSVC FALSE)
    elseif(CMAKE_CXX_COMPILER_ID STREQUAL "GNU")
        set(USE_GCC TRUE)
        set(USE_CLANG FALSE)
        set(USE_MSVC FALSE)
    elseif(MSVC)
        set(USE_MSVC TRUE)
        set(USE_CLANG FALSE)
        set(USE_GCC FALSE)
    else()
        set(USE_CLANG TRUE)
        set(USE_GCC FALSE)
        set(USE_MSVC FALSE)
    endif()
    set(IS_SUPPORTED_COMPILER TRUE)
endmacro()

